{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🤖 Abrir Claude Code",
      "type": "shell",
      "command": "claude",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true,
        "clear": false
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "🚀 Iniciar Expo",
      "type": "shell",
      "command": "npx expo start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": [],
      "isBackground": true
    }
  ]
}
